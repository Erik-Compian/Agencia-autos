@model AgenciaAutosMVC.Models.Cliente

<div class="container mt-4">
    <h2>Registrar Nuevo Cliente</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Nuevo" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre(s)</label>
                            <input asp-for="Nombre" class="form-control" required placeholder="Ej. Juan" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Apellido(s)</label>
                            <input asp-for="Apellido" class="form-control" required placeholder="Ej. Pérez" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" required placeholder="10 dígitos" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo Electrónico</label>
                            <input asp-for="Email" type="email" class="form-control" required placeholder="correo@ejemplo.com" />
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Clientes" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">💾 Guardar Cliente</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>