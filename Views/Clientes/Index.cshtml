@model IEnumerable<AgenciaAutosMVC.Models.Cliente>

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2>Directorio de Clientes</h2>
    <a href="/Clientes/Nuevo" class="btn btn-success fw-bold">+ Nuevo Cliente</a>
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group" style="max-width: 500px;">
        <input type="text" name="buscar" class="form-control"
               placeholder="Buscar por nombre, teléfono o email..."
               value="@ViewBag.BusquedaActual" />
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a href="/Clientes" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<div class="table-responsive shadow-sm border rounded bg-white">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre Completo</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">
                        No se encontraron clientes.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var cliente in Model)
                {
                    <tr>
                        <td class="align-middle text-muted">#@cliente.IdCliente</td>
                        <td class="align-middle fw-bold">@cliente.Nombre @cliente.Apellido</td>
                        <td class="align-middle">
                            <a href="tel:@cliente.Telefono" class="text-decoration-none text-dark" title="Llamar ahora">
                                 @cliente.Telefono
                            </a>
                        </td>
                        <td class="align-middle">
                            <a href="mailto:@cliente.Email" class="text-decoration-none" title="Enviar correo">
                                 @cliente.Email
                            </a>
                        </td>
                        <td class="align-middle text-center">
                            <div class="btn-group">
                                <a href="/Clientes/Editar/@cliente.IdCliente" class="btn btn-sm btn-warning fw-bold">Editar</a>
                                <form asp-action="Eliminar" asp-route-id="@cliente.IdCliente" method="post"
                                      onsubmit="return confirm('¿Seguro que deseas eliminar a este cliente?');" class="d-inline ms-1">
                                    <button type="submit" class="btn btn-sm btn-danger fw-bold">Eliminar</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>