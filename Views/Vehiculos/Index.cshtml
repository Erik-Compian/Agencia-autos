@model IEnumerable<AgenciaAutosMVC.Models.Vehiculo>

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2>Catálogo de Vehículos</h2>
    <a href="/Vehiculos/Create" class="btn btn-success">Registrar Vehículo</a>
</div>

<div class="table-responsive shadow-sm border rounded">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>Dueño (Cliente)</th>
                <th>Vehículo (Marca, Modelo, Año)</th>
                <th>Placa</th>
                <th>Color</th>
                <th>Km Actual</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var auto in Model)
            {
                <tr>
                    <td class="align-middle">@auto.IdClienteNavigation.Nombre @auto.IdClienteNavigation.Apellido</td>
                    <td class="align-middle fw-bold text-primary">
                        @auto.IdModeloNavigation.IdMarcaNavigation.Nombre @auto.IdModeloNavigation.Nombre (@auto.IdModeloNavigation.Anio)
                    </td>
                    <td class="align-middle">@auto.Placa</td>
                    <td class="align-middle">@auto.Color</td>
                    <td class="align-middle">@auto.KmActual km</td>
                    <td class="align-middle">
                        <a href="/Vehiculos/Edit/@auto.IdVehiculo" class="btn btn-sm btn-warning">Editar</a>
                        <a href="/Vehiculos/Delete/@auto.IdVehiculo" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>