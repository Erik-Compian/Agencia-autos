@model AgenciaAutosMVC.Models.Vehiculo

<div class="card shadow-sm mt-4">
    <div class="card-header bg-dark text-white">
        <h3 class="mb-0">Registrar Nuevo Vehículo</h3>
    </div>
    <div class="card-body">
        <form asp-controller="Vehiculos" asp-action="Create" method="post">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Dueño (Cliente):</label>
                    <select name="IdCliente" asp-items="ViewBag.Clientes" class="form-select" required>
                        <option value="">-- Seleccione un Cliente --</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Modelo del Vehículo:</label>
                    <select name="IdModelo" asp-items="ViewBag.Modelos" class="form-select" required>
                        <option value="">-- Seleccione un Modelo --</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Número de Serie (VIN):</label>
                    <input type="text" name="NumSerie" class="form-control" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Placa:</label>
                    <input type="text" name="Placa" class="form-control" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Color:</label>
                    <input type="text" name="Color" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Kilometraje Actual:</label>
                    <input type="number" name="KmActual" class="form-control" value="0" required />
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">Guardar en Base de Datos</button>
                <a href="/Vehiculos" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>