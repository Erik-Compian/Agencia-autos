@model IEnumerable<AgenciaAutosMVC.Models.Refaccion>

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2>Catálogo de Refacciones e Inventario</h2>
    <a href="/Catalogos/CrearRefaccion" class="btn btn-success fw-bold">+ Nueva Refacción</a>
</div>

<form asp-action="Refacciones" method="get" class="mb-4">
    <div class="input-group" style="max-width: 450px;">
        <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre de pieza..." value="@ViewBag.BusquedaActual" />
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a href="/Catalogos/Refacciones" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<div class="table-responsive shadow-sm border rounded bg-white">
    <table class="table table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre de la Refacción</th>
                <th>Precio Unitario</th>
                <th>Stock en Almacén</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td class="align-middle text-muted">#@r.IdRefaccion</td>
                    <td class="align-middle fw-bold">@r.Nombre</td>
                    <td class="align-middle text-success fw-bold">$@r.Precio.ToString("N2")</td>
                    <td class="align-middle">
                        @if (r.Stock <= 5)
                        {
                            <span class="badge bg-danger p-2" title="¡Urgente resurtir!">
                                ⚠️ @r.Stock unidades
                            </span>
                        }
                        else if (r.Stock <= 15)
                        {
                            <span class="badge bg-warning text-dark p-2">
                                📦 @r.Stock unidades
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark p-2">
                                ✅ @r.Stock unidades
                            </span>
                        }
                    </td>
                    <td class="align-middle text-center">
                        <a href="/Catalogos/EditarRefaccion/@r.IdRefaccion" class="btn btn-sm btn-outline-primary">
                            Editar / Surtir
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>