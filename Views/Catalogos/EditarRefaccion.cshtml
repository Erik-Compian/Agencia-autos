@model AgenciaAutosMVC.Models.Refaccion

@{
    ViewData["Title"] = "Editar Refacción";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"> Editar Refacción / Surtir Almacén</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditarRefaccion" method="post">
                        <input type="hidden" asp-for="IdRefaccion" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre de la Refacción</label>
                            <input asp-for="Nombre" class="form-control bg-light" readonly />
                            <small class="text-muted">El nombre no se puede editar para mantener consistencia.</small>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Precio Unitario ($)</label>
                                <input asp-for="Precio" type="number" step="0.01" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Stock Actual (Piezas)</label>
                                <input asp-for="Stock" type="number" class="form-control" required />
                                <small class="text-info">Cambia este número para surtir el inventario.</small>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success fw-bold">Guardar Cambios / Surtir</button>
                            <a href="/Catalogos/Refacciones" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>