@model IEnumerable<AgenciaAutosMVC.Models.ProximoServicio>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Agenda de Próximos Servicios</h2>
        <div class="badge bg-info text-dark p-2">Seguimiento de Clientes</div>
    </div>

    <form asp-action="Proximos" method="get" class="mb-4">
        <div class="input-group" style="max-width: 500px;">
            <input type="text" name="buscar" class="form-control" placeholder="Buscar por Folio o Nombre del Dueño..." />
            <button type="submit" class="btn btn-primary">🔍 Buscar</button>
            <a href="/Servicios/Proximos" class="btn btn-outline-secondary">Limpiar</a>
        </div>
    </form>
    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Folio Origen</th>
                        <th>Vehículo</th>
                        <th>Dueño</th>
                        <th>Fecha Programada</th>
                        <th>Km Sugerido</th>
                        <th>Notas</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.Folio</td>
                            <td>
                                <strong>@item.FolioNavigation.IdVehiculoNavigation.Placa</strong>
                            </td>
                            <td>@item.FolioNavigation.IdVehiculoNavigation.IdClienteNavigation.Nombre</td>
                            <td>
                                <span class="fw-bold text-primary">
                                    @item.FechaProg.ToString("dd/MM/yyyy")
                                </span>
                            </td>
                            <td>@item.KmProximo km</td>
                            <td class="text-muted small">@item.Notas</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No hay servicios programados aún.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>