@model AgenciaAutosMVC.Models.Servicio
@{
    Layout = null;
    // Calculamos el total de refacciones aquí arriba para limpiar el HTML
    decimal totalRefacciones = Model.ServicioRefaccions.Sum(sr => sr.Cantidad * sr.PrecioAplicado);
    // Asumimos que el tipo de servicio tiene un costo base (Mano de Obra)
    decimal costoManoObra = Model.IdTipoServNavigation.Precio; // Revisa si en tu BD es 'Precio' o 'Costo'
    decimal granTotal = totalRefacciones + costoManoObra;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Comprobante de Servicio #@Model.Folio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
            padding: 20px;
            font-family: 'Courier New', Courier, monospace;
        }

        .ticket {
            background: white;
            max-width: 450px;
            margin: 0 auto;
            padding: 25px;
            border: 1px solid #ddd;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        .centrado {
            text-align: center;
        }

        .separador {
            border-top: 1px dashed #333;
            margin: 15px 0;
        }

        table {
            font-size: 0.9rem;
        }

        @@media print {
            .no-imprimir {
                display: none !important;
            }

            body {
                background-color: white;
                padding: 0;
            }

            .ticket {
                border: none;
                max-width: 100%;
                box-shadow: none;
            }
        }
    </style>
</head>
<body>

    <div class="ticket">
        <div class="centrado">
            @using AgenciaAutosMVC.Services
            @{
                var config = ConfiguradorAgencia.Instancia;
            }

            <h3 class="fw-bold mb-0">@config.NombreAgencia.ToUpper()</h3>
            <p class="small mb-0">@config.Direccion</p>
            <p class="small">Tel: @config.Telefono</p>

            <div class="separador"></div>

            <h5 class="mb-0">ORDEN DE SERVICIO</h5>
            <p class="mb-0">Folio: <strong>#@Model.Folio</strong></p>
            <p class="small">Fecha: @Model.FechaIngreso.ToShortDateString()</p>
        </div>

        <div class="mt-3">
            <p class="mb-1 small"><strong>CLIENTE:</strong> @Model.IdVehiculoNavigation.IdClienteNavigation.Nombre @Model.IdVehiculoNavigation.IdClienteNavigation.Apellido</p>
            <p class="mb-1 small"><strong>AUTO:</strong> @Model.IdVehiculoNavigation.IdModeloNavigation.IdMarcaNavigation.Nombre @Model.IdVehiculoNavigation.IdModeloNavigation.Nombre</p>
            <p class="mb-1 small"><strong>PLACAS:</strong> @Model.IdVehiculoNavigation.Placa</p>
        </div>

        <div class="separador"></div>

        <h6 class="fw-bold">DETALLE DE CARGOS</h6>
        <table class="table table-sm table-borderless">
            <tbody>
                <tr>
                    <td>Mano de Obra (@Model.IdTipoServNavigation.Nombre)</td>
                    <td class="text-end">@costoManoObra.ToString("C")</td>
                </tr>
                @if (Model.ServicioRefaccions.Any())
                {
                    <tr>
                        <td colspan="2"><small><strong>Refacciones utilizadas:</strong></small></td>
                    </tr>
                    @foreach (var item in Model.ServicioRefaccions)
                    {
                        <tr>
                            <td class="ps-3 small">@item.Cantidad x @item.IdRefaccionNavigation.Nombre</td>
                            <td class="text-end small">@((item.Cantidad * item.PrecioAplicado).ToString("C"))</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <td class="pt-2 fw-bold">TOTAL A PAGAR:</td>
                    <td class="pt-2 fw-bold text-end" style="font-size: 1.2rem;">@granTotal.ToString("C")</td>
                </tr>
            </tfoot>
        </table>

        <div class="separador"></div>

        <p class="small"><strong>Observaciones:</strong> @Model.Descripcion</p>

        <div class="centrado mt-4">
            <p class="mb-0">_________________________</p>
            <p class="small">Firma del Cliente</p>
            <p class="mt-3 small text-muted">¡Gracias por su confianza!</p>
        </div>

        <div class="centrado mt-4 no-imprimir">
            <button onclick="window.print()" class="btn btn-primary w-100 mb-2">Imprimir Ticket</button>
            <a href="/Servicios" class="btn btn-outline-secondary btn-sm w-100">Regresar al Taller</a>
        </div>
    </div>

</body>
</html>