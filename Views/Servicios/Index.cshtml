@model IEnumerable<AgenciaAutosMVC.Models.Servicio>

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2>Control de Taller (Servicios)</h2>
    <a href="/Servicios/Recepcion" class="btn btn-success fw-bold">+ Nueva Recepción</a>
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group" style="max-width: 500px;">
        <input type="text" name="buscar" class="form-control"
               placeholder="Buscar por Folio, Dueño o Placa..."
               value="@ViewBag.BusquedaActual" />
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a href="/Servicios" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<div class="table-responsive shadow-sm border rounded bg-white">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>Folio</th>
                <th>Vehículo</th>
                <th>Dueño</th>
                <th>Tipo</th>
                <th>Ingreso</th>
                <th>Salida</th>
                <th>Estatus</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">
                        <p class="mb-0">No se encontraron servicios registrados.</p>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var servicio in Model)
                {
                    <tr>
                        <td class="align-middle fw-bold">#@servicio.Folio</td>
                        <td class="align-middle">
                            <strong>
                                @servicio.IdVehiculoNavigation.IdModeloNavigation.IdMarcaNavigation.Nombre
                                @servicio.IdVehiculoNavigation.IdModeloNavigation.Nombre
                            </strong>
                            <br><small class="text-muted">Placa: @servicio.IdVehiculoNavigation.Placa</small>
                        </td>
                        <td class="align-middle">@servicio.IdVehiculoNavigation.IdClienteNavigation.Nombre</td>
                        <td class="align-middle">@servicio.IdTipoServNavigation.Nombre</td>
                        <td class="align-middle">@servicio.FechaIngreso.ToShortDateString()</td>

                        <td class="align-middle">
                            @if (servicio.FechaSalida != null)
                            {
                                <span class="badge bg-light text-dark border">
                                    @servicio.FechaSalida.Value.ToShortDateString()
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">--/--/----</span>
                            }
                        </td>

                        <td class="align-middle">
                            @if (servicio.Estatus == "En espera")
                            {
                                <span class="badge bg-danger">En espera</span>
                            }
                            else if (servicio.Estatus == "En proceso")
                            {
                                <span class="badge bg-warning text-dark">En proceso</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Finalizado</span>
                            }
                        </td>

                        <td class="align-middle">
                            <div class="btn-group-vertical w-100">
                                <a href="/Servicios/Comprobante/@servicio.Folio" class="btn btn-sm btn-outline-secondary mb-1" target="_blank"> Imprimir</a>

                                @if (servicio.Estatus == "Finalizado")
                                {
                                    <span class="badge bg-secondary p-2 mt-1 shadow-sm"> Bloqueado por Sistema</span>
                                }
                                else
                                {
                                    <a href="/Servicios/Actualizar/@servicio.Folio" class="btn btn-sm btn-outline-primary fw-bold mb-1">✏️ Actualizar</a>
                                    <a href="/Servicios/Refacciones/@servicio.Folio" class="btn btn-sm btn-outline-info mb-1"> Refacciones</a>

                                    <form asp-action="Eliminar" asp-route-id="@servicio.Folio" method="post"
                                          onsubmit="return confirm('¿Eliminar Folio #@servicio.Folio de forma permanente?');">
                                        <button type="submit" class="btn btn-sm btn-danger fw-bold w-100"> Eliminar</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>