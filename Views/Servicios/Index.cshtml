@model IEnumerable<AgenciaAutosMVC.Models.Servicio>

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2>Control de Taller (Servicios)</h2>
    <a href="/Servicios/Recepcion" class="btn btn-success fw-bold">+ Nueva Recepción</a>
</div>

<div class="table-responsive shadow-sm border rounded bg-white">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>Folio</th>
                <th>Vehículo</th>
                <th>Dueño</th>
                <th>Tipo</th>
                <th>Ingreso</th>
                <th>Estatus</th>
                <th>Atiende</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var servicio in Model)
            {
                <tr>
                    <td class="align-middle fw-bold">#@servicio.Folio</td>
                    <td class="align-middle">
                        @servicio.IdVehiculoNavigation.IdModeloNavigation.IdMarcaNavigation.Nombre
                        @servicio.IdVehiculoNavigation.IdModeloNavigation.Nombre
                        <br><small class="text-muted">Placa: @servicio.IdVehiculoNavigation.Placa</small>
                    </td>
                    <td class="align-middle">@servicio.IdVehiculoNavigation.IdClienteNavigation.Nombre</td>
                    <td class="align-middle">@servicio.IdTipoServNavigation.Nombre</td>
                    <td class="align-middle">@servicio.FechaIngreso</td>
                    <td class="align-middle">
                        @if (servicio.Estatus == "En espera")
                        {
                            <span class="badge bg-danger">@servicio.Estatus</span>
                        }
                        else if (servicio.Estatus == "En proceso")
                        {
                            <span class="badge bg-warning text-dark">@servicio.Estatus</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@servicio.Estatus</span>
                        }
                    </td>
                    <td class="align-middle">
                        <a href="/Servicios/Actualizar/@servicio.Folio" class="btn btn-sm btn-outline-primary fw-bold">Actualizar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>